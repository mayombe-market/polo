# ═══ Copier vers .env.local (dev) ou renseigner dans Vercel → Settings → Environment Variables ═══

# Supabase (obligatoire) — Projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (emails transactionnels : confirmations, etc.) — https://resend.com/api-keys
# Sans clé, les appels à resend.emails.send échoueront au runtime.
RESEND_API_KEY=re_xxxxxxxx

# Google Analytics 4 (optionnel) — remplacer par votre ID de mesure (Admin GA → Flux)
# Renseigner surtout en prod (Vercel → Environment Variables → Production).
# En local : même avec cette variable dans .env.local, gtag ne se charge pas (next dev = pas de stats).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudinary (upload + delivery) — https://cloudinary.com/console
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ═══ Après déploiement Vercel ═══
# Dans Supabase : Authentication → URL Configuration
#   - Site URL : https://votre-projet.vercel.app (ou domaine custom)
#   - Redirect URLs (exemples, une ligne par URL ou wildcard selon besoin) :
#       https://votre-projet.vercel.app/auth/callback
#       https://votre-projet.vercel.app/reset-password
#       http://localhost:3000/auth/callback
#       http://localhost:3000/reset-password
