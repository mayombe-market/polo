# ═══ Copier vers .env.local (dev) ou renseigner dans Vercel → Settings → Environment Variables ═══

# Supabase (obligatoire) — Projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cron (expiration campagnes pub vendeur) — /api/cron/ad-campaigns + Vercel Cron
# CRON_SECRET=...
# SUPABASE_SERVICE_ROLE_KEY=...  (service_role, jamais côté client)

# Resend (emails transactionnels : confirmations, etc.) — https://resend.com/api-keys
# Sans clé, les appels à resend.emails.send échoueront au runtime.
RESEND_API_KEY=re_xxxxxxxx

# Google Analytics 4 (optionnel) — remplacer par votre ID de mesure (Admin GA → Flux)
# Renseigner surtout en prod (Vercel → Environment Variables → Production).
# En local : même avec cette variable dans .env.local, gtag ne se charge pas (next dev = pas de stats).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudinary (upload + delivery) — https://cloudinary.com/console
# Upload serveur (/api/upload) : CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET (obligatoires, jamais en NEXT_PUBLIC).
# Nom du cloud : CLOUDINARY_CLOUD_NAME et/ou NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME (même valeur Dashboard →
# « Cloud name ») — le code serveur accepte l’un ou l’autre pour l’upload.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_URL=   (alternative : cloudinary://API_KEY:API_SECRET@CLOUD_NAME)

# Supabase auth côté client (useAuth / safeGetUser) — délai ms (défaut 10000 si absent)
# NEXT_PUBLIC_SUPABASE_GETUSER_TIMEOUT_MS=15000

# Debug : log console des src d’images (ProductCard, CloudinaryImage) — détecte aussi /_next/image par erreur
# NEXT_PUBLIC_DEBUG_IMAGE_SRC=1

# ═══ Après déploiement Vercel ═══
# Dans Supabase : Authentication → URL Configuration
#   - Site URL : https://votre-projet.vercel.app (ou domaine custom)
#   - Redirect URLs (exemples, une ligne par URL ou wildcard selon besoin) :
#       https://votre-projet.vercel.app/auth/callback
#       https://votre-projet.vercel.app/reset-password
#       http://localhost:3000/auth/callback
#       http://localhost:3000/reset-password

# ─── MTN MoMo (Collections API) ────────────────────────────────────────────
# Sandbox  : https://momodeveloper.mtn.com → Create account → Subscribe to Collections
# Production Congo : contacter MTN Congo entreprise pour les clés partenaire
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_ENVIRONMENT=sandbox               # sandbox | production
MTN_MOMO_SUBSCRIPTION_KEY=                 # Primary Key depuis le portail développeur
MTN_MOMO_USER_ID=                          # UUID créé via API ou portail sandbox
MTN_MOMO_API_KEY=                          # API Key générée depuis le portail

# URL appelée par MTN dès que le paiement est confirmé (doit être HTTPS public)
# Format attendu : https://votre-domaine.com/api/mtn-momo/callback
MTN_MOMO_CALLBACK_URL=https://votre-domaine.com/api/mtn-momo/callback

# Token secret ajouté en query param (?secret=...) pour valider les appels webhook
# Générer avec : openssl rand -hex 32
MTN_MOMO_WEBHOOK_SECRET=
